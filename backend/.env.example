# ============================================================
# UyTa'mir Backend – Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------------
# Application
# ------------------------------------------------------------------
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-use-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Comma-separated list of allowed CORS origins
CORS_ORIGINS_STR=http://localhost:3000,http://localhost:5173

# ------------------------------------------------------------------
# Database (PostgreSQL)
# ------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://uytamir:password@localhost:5432/uytamir_db

# ------------------------------------------------------------------
# Redis
# ------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------
# S3-compatible Object Storage
# ------------------------------------------------------------------
S3_BUCKET=uytamir-media
S3_REGION=us-east-1
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
# Leave blank to use AWS S3; set to e.g. https://s3.uz for local/minio
S3_ENDPOINT_URL=

# ------------------------------------------------------------------
# SMS Gateway
# Supported: eskiz | playmobile
# ------------------------------------------------------------------
SMS_PROVIDER=eskiz
SMS_SENDER_ID=UyTamir

# Eskiz credentials
ESKIZ_EMAIL=you@example.com
ESKIZ_PASSWORD=your-eskiz-password

# Playmobile credentials (used when SMS_PROVIDER=playmobile)
PLAYMOBILE_URL=https://send.smsxabar.uz/broker-api/send
PLAYMOBILE_LOGIN=your-login
PLAYMOBILE_PASSWORD=your-password

# ------------------------------------------------------------------
# Sentry (optional – leave blank to disable)
# ------------------------------------------------------------------
SENTRY_DSN=

# ------------------------------------------------------------------
# AI Features
# Set AI_FEATURES_ENABLED=true and provide OPENAI_API_KEY to enable
# ------------------------------------------------------------------
AI_FEATURES_ENABLED=true
AI_MODEL_BUILDER=gpt-4-turbo
AI_MODEL_EXPLAINER=gpt-4-mini
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
